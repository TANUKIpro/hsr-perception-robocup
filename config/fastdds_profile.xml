<?xml version="1.0" encoding="UTF-8" ?>
<!--
FastDDS Profile for HSR Perception

Disables Shared Memory (SHM) transport to prevent race conditions when
Streamlit starts before ROS2 camera nodes. Without this, FastDDS SHM can
cause discovery failures depending on process startup order.

Uses the userTransports + UDPv4-only pattern supported by FastDDS shipped
with ROS2 Humble. See:
https://fast-dds.docs.eprosima.com/en/latest/fastdds/transport/disabling_multicast.html
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <profiles>
        <transport_descriptors>
            <transport_descriptor>
                <transport_id>udp_transport</transport_id>
                <type>UDPv4</type>
            </transport_descriptor>
        </transport_descriptors>

        <participant profile_name="participant_profile" is_default_profile="true">
            <rtps>
                <!-- Use the UDPv4 transport we declared above, and turn off
                     the built-in transports (which includes SHM). -->
                <userTransports>
                    <transport_id>udp_transport</transport_id>
                </userTransports>
                <useBuiltinTransports>false</useBuiltinTransports>
            </rtps>
        </participant>
    </profiles>
</dds>
